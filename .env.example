# ============================================================
#  Affirmer Training App — environment variables
#
#  You ONLY need the 4 keys in the first two blocks to get running.
#  Everything below "OPTIONAL" can be left out — the app works without it.
#
#  • Local: copy this file to ".env.local" and fill in the values.
#  • Vercel: add each as an Environment Variable in your project settings.
#  NEVER put real keys in a file you commit to GitHub. .env.local is git-ignored.
# ============================================================

# ---- Supabase (REQUIRED) ----  Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ---- Gemini (REQUIRED) ----  https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key

# ============================================================
#  OPTIONAL — sensible defaults are built in. Skip unless you need these.
# ============================================================

# Cheapest Gemini tier: set model to gemini-2.0-flash-lite-preview
# GEMINI_MODEL=gemini-2.0-flash
# gemini-embedding-001 replaced text-embedding-004 (shut down Jan 2026); 768-dim output requested
# GEMINI_EMBED_MODEL=gemini-embedding-001

# Lock the /setup page with a password so you can re-run setup later.
# If you leave this unset, /setup works once and then locks itself automatically.
# SEED_SECRET=

# Default demo login email (you can also just type it on the /setup page).
# SEED_EMAIL=you@yourcompany.com

# Only needed if you ever host the app on a custom domain AND magic-link
# redirects misbehave. Normally the app figures out its own URL.
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ---- Upgraded voice (OPTIONAL) ----
# Voice works for free in the browser by default. To use cloud voices instead:
# TTS_PROVIDER=azure
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=
# STT_PROVIDER=openai          # or "deepgram"
# OPENAI_API_KEY=
# DEEPGRAM_API_KEY=

# ---- Hosted video (OPTIONAL) ----
# VIMEO_ACCESS_TOKEN=

# ---- Tuning (OPTIONAL) ----
# TUTOR_RATE_LIMIT_PER_MIN=8
# SIGNED_URL_TTL_SECONDS=600
