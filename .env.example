# ───────────────────────────────────────────────────────────────
#  Affirmer Training App — environment variables
#  Copy to .env.local and fill in. Only the SUPABASE + GEMINI blocks
#  are required to run the MVP. Everything else is optional / opt-in.
# ───────────────────────────────────────────────────────────────

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Supabase (REQUIRED) ----
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. NEVER expose to the browser. Used by seed/embed scripts + admin tasks.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Gemini (REQUIRED for the AI tutor + embeddings) ----
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key
# gemini-2.0-flash (default) or gemini-2.0-flash-lite-preview for the cheapest tier
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=text-embedding-004   # 768-dim, matches the DB vector size

# ---- Seeding ----
# The demo worker's email — use a real inbox you control (this is who you log in as).
SEED_EMAIL=you@yourdomain.com
# Required ONLY if you seed via the one-time /api/admin/seed endpoint (Vercel-only,
# no terminal). Set this to any long random string; you pass it as ?key=... once.
# Leave unset if you seed with `npm run seed`.
SEED_SECRET=

# ---- Voice: Text-to-Speech ----
# Default MVP uses the FREE in-browser Web Speech API (no key needed).
# Set TTS_PROVIDER=azure to use Azure Neural TTS for dynamic Q&A answers.
TTS_PROVIDER=webspeech          # webspeech | azure
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=            # e.g. australiaeast

# ---- Voice: Speech-to-Text (voice questions) ----
# Default MVP uses the FREE in-browser SpeechRecognition API (no key needed).
# Set STT_PROVIDER=whisper or =deepgram to transcribe server-side.
STT_PROVIDER=webspeech          # webspeech | whisper | deepgram
OPENAI_API_KEY=                 # for whisper
DEEPGRAM_API_KEY=               # for deepgram

# ---- Video hosting (Vimeo) ----
# Optional. Slides store a vimeo_id; the player embeds it with privacy params.
# A token is only needed if you call the Vimeo API (not required to embed).
VIMEO_ACCESS_TOKEN=

# ---- Cost guardrails ----
TUTOR_RATE_LIMIT_PER_MIN=8      # per-user requests/min on /api/tutor
SIGNED_URL_TTL_SECONDS=600      # short-lived signed URLs for stored audio
